---
interface Props { lang: 'th' | 'en'; }
const { lang } = Astro.props;
const footerCredit = lang === 'en'
  ? 'Designed by <a href="http://www.elegantthemes.com" title="Premium WordPress Themes">Elegant Themes</a> | Powered by <a href="http://www.wordpress.org">WordPress</a>'
  : 'ออกแบบโดย <a href="http://www.elegantthemes.com" title="Premium WordPress Themes">Elegant Themes</a> | ดำเนินการโดย <a href="http://www.wordpress.org">WordPress</a>';
---
<footer id="main-footer">
  <div class="container">
    <div id="footer-widgets" class="clearfix">
      <div class="footer-widget">
        <div id="text-4" class="fwidget et_pb_widget widget_text">
          <div class="textwidget">
            <p>
              <img src="/media/logo_foot.png" alt="Opendream" />
              <br />
              Copyright &copy; 2017 opendream All rights reserved.
            </p>
          </div>
        </div>
        <div id="text-5" class="fwidget et_pb_widget widget_text">
          <div class="textwidget">
            <p><strong>Sustainable Social Impact with Technology</strong></p>
            <p>
              <a id="ic_fb" href="https://www.facebook.com/opendream">
                <img src="/media/ic_fb.svg" alt="opendream facebook" />
              </a>
              &nbsp;
              <a id="ic_tw" href="https://twitter.com/opendream">
                <img src="/media/ic_tw.svg" alt="opendream twitter" />
              </a>
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div id="footer-bottom">
    <div class="container clearfix">
      <p id="footer-info" set:html={footerCredit} />
    </div>
  </div>
</footer>
