---
import Nav from './Nav.astro';
interface Props { lang: 'th' | 'en'; thHref?: string; enHref?: string; }
const { lang, thHref = '/blog', enHref = '/en/blogs' } = Astro.props;
const homeHref = lang === 'en' ? '/en/' : '/';
const menuLabel = lang === 'en' ? 'Menu' : 'เมนู';
---
<header class="od-header">
  <div class="od-header__inner">
    <a href={homeHref} class="od-logo"><img src="/media/od_logo.svg" alt="Opendream" /></a>
    <button class="od-burger" id="od-burger" type="button" aria-label={menuLabel} aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
    <nav class="od-nav" aria-label={menuLabel}>
      <Nav lang={lang} thHref={thHref} enHref={enHref} />
    </nav>
  </div>
</header>
<script is:inline>
  (() => {
    const header = document.querySelector('.od-header');
    const burger = document.getElementById('od-burger');
    if (!header || !burger) return;
    burger.addEventListener('click', () => {
      const open = header.classList.toggle('od-nav-open');
      burger.setAttribute('aria-expanded', open ? 'true' : 'false');
    });
  })();
</script>
