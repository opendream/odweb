---
// Clean, de-Divi'd hero banner for the blog/press listing (was the live blog section_0).
interface Props { title: string; subtitle: string; }
const { title, subtitle } = Astro.props;
---
<section class="od-hero">
  <div class="od-hero__inner">
    <h1 class="od-hero__title">{title}</h1>
    <p class="od-hero__subtitle">{subtitle}</p>
  </div>
</section>
