---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Picture from '../../components/Picture.astro';
import { getCollection } from 'astro:content';
import projectConfig from '../../data/projects.config.json';
import { gradientFor } from '../../lib/gradient.mjs';
import { organizationLd, websiteLd } from '../../lib/seo.mjs';
const all = await getCollection('projects');
const bySlug = Object.fromEntries(all.map((p) => [p.data.slug, p.data]));
const tiles = (projectConfig.en.featured ?? []).map((s) => bySlug[s]).filter(Boolean);
const origin = Astro.site!.origin;
const description = 'Opendream is a social-impact technology partner designing and building digital systems with organizations creating lasting public value.';
const jsonLd = [organizationLd(origin), websiteLd(origin, 'en')];
---
<BaseLayout title="Opendream — Open by Design. Build for Impact." description={description} lang="en" path="/en" altPath="/" jsonLd={jsonLd}>
  <section class="od-home-hero">
    <h1 class="od-home-hero__title">Open by Design.<br /><span>Build for Impact.</span></h1>
  </section>
  <div class="od-showcase">
    {tiles.map((t, i) => (
      <a href={t.path} class="od-showcase__tile">
        {t.cover
          ? <Picture src={t.cover} alt={t.title} loading={i === 0 ? 'eager' : 'lazy'} fetchpriority={i === 0 ? 'high' : undefined} />
          : <span class="od-ph" style={`background:${gradientFor(t.slug)}`}>{t.title}</span>}
        {t.cover && (
          <div class="od-showcase__overlay">
            <span class="od-showcase__name">{t.title}</span>
          </div>
        )}
      </a>
    ))}
  </div>
</BaseLayout>
