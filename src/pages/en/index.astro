---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import projectConfig from '../../data/projects.config.json';
const all = await getCollection('projects');
const bySlug = Object.fromEntries(all.map((p) => [p.data.slug, p.data]));
const tiles = (projectConfig.en.featured ?? []).map((s) => bySlug[s]).filter(Boolean);
---
<BaseLayout title="Opendream — Sustainable Social Impact with Technology" lang="en" path="/en/" altPath="/">
  <section class="od-home-hero">
    <p class="od-home-hero__pre">We create</p>
    <h1 class="od-home-hero__title">Sustainable Social Impact<br />with <span>Technology</span></h1>
  </section>
  <section class="od-section">
    <div class="od-container">
      <div class="od-showcase">
        {tiles.map((t) => (
          <a href={t.path} class="od-showcase__tile">
            {t.cover && <img src={t.cover} alt={t.title} />}
            <div class="od-showcase__cap">
              <span class="od-showcase__name">{t.title}</span>
              {t.type && <span class="od-showcase__type">{t.type}</span>}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
