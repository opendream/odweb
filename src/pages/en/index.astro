---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import projectConfig from '../../data/projects.config.json';
import { gradientFor } from '../../lib/gradient.mjs';
const all = await getCollection('projects');
const bySlug = Object.fromEntries(all.map((p) => [p.data.slug, p.data]));
const tiles = (projectConfig.en.featured ?? []).map((s) => bySlug[s]).filter(Boolean);
---
<BaseLayout title="Opendream — Open by Design. Build for Impact." lang="en" path="/en/" altPath="/">
  <section class="od-home-hero">
    <h1 class="od-home-hero__title">Open by Design.<br /><span>Build for Impact.</span></h1>
  </section>
  <div class="od-showcase">
    {tiles.map((t) => (
      <a href={t.path} class="od-showcase__tile">
        {t.cover
          ? <img src={t.cover} alt={t.title} />
          : <span class="od-ph" style={`background:${gradientFor(t.slug)}`}>{t.title}</span>}
        {t.cover && (
          <div class="od-showcase__overlay">
            <span class="od-showcase__name">{t.title}</span>
          </div>
        )}
      </a>
    ))}
  </div>
</BaseLayout>
