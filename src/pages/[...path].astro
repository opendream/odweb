---
import { getCollection, render } from 'astro:content';
import PostLayout from '../layouts/PostLayout.astro';
import ProjectLayout from '../layouts/ProjectLayout.astro';
import PageLayout from '../layouts/PageLayout.astro';
import ComposedLayout from '../layouts/ComposedLayout.astro';
import Hero from '../components/content/Hero.astro';
import Section from '../components/content/Section.astro';
import Blurbs from '../components/content/Blurbs.astro';
import Blurb from '../components/content/Blurb.astro';
import Gallery from '../components/content/Gallery.astro';
import Map from '../components/content/Map.astro';
import CTA from '../components/content/CTA.astro';
import Button from '../components/content/Button.astro';

// Components available to `pages` MDX without per-file imports (clean, CMS-friendly content).
const mdxComponents = { Hero, Section, Blurbs, Blurb, Gallery, Map, CTA, Button };

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  const projects = await getCollection('projects');
  const policies = await getCollection('policies');
  const pages = await getCollection('pages');
  const col = (entry, kind) => ({ params: { path: entry.data.path.replace(/^\//, '') }, props: { kind, entry } });
  return [
    ...posts.map((e) => col(e, 'post')),
    ...projects.map((e) => col(e, 'project')),
    ...policies.map((e) => col(e, 'policy')),
    ...pages.map((e) => col(e, 'page-mdx')),
  ];
}

const props = Astro.props;
const { Content } = await render(props.entry);
const d = props.entry.data;
---
{props.kind === 'project' ? (
  <ProjectLayout title={d.title} lang={d.lang} path={d.path} cover={d.cover} description={d.excerpt} issues={d.issues} type={d.type} year={d.year} partners={d.partners}>
    <Content />
  </ProjectLayout>
) : props.kind === 'policy' ? (
  <PageLayout title={d.title} lang={d.lang} path={d.path}>
    <Content />
  </PageLayout>
) : props.kind === 'page-mdx' ? (
  <ComposedLayout title={d.title} lang={d.lang} path={d.path} description={d.description}>
    <Content components={mdxComponents} />
  </ComposedLayout>
) : (
  <PostLayout title={d.title} date={d.date} lang={d.lang} path={d.path} cover={d.cover} description={d.excerpt}>
    <Content />
  </PostLayout>
)}
